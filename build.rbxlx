		BundleId = 239,        -- "Woman" body bundle (free, official Roblox)
		SkipBundleHead = false,
		LayeredClothing = {
			{ AssetId = 16438934852, Type = "Shirt" },  -- starter top
			{ AssetId = 16439116620, Type = "Pants" },   -- starter bottom
		},
	},
	Male = {
